      "required": true
    },
    "hdUrl": {
      "type": "string"
    },
    "nasaDate": {
      "type": "date",
      "required": true,
      "unique": true
    },
    "mediaType": {
      "type": "string"
    },
    "copyright": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
